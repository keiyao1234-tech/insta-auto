# ローカル検証用テンプレート。
# 本番値は GitHub Actions の Secrets に登録し、.env は絶対にコミットしないこと。

# --- Instagram (Instagram Login / graph.instagram.com) ---
IG_ACCESS_TOKEN=        # 長期アクセストークン（約60日・自動リフレッシュ対象）
IG_USER_ID=             # プロアカウントの user id  ( GET graph.instagram.com/me?fields=user_id )
IG_APP_ID=              # Meta アプリ ID
IG_APP_SECRET=          # Meta アプリ シークレット

# --- 通知 ---
DISCORD_WEBHOOK_URL=    # 失敗アラート用 Discord Webhook URL（任意）

# --- メディアの公開 raw URL 生成用（自分のGitHub公開リポ） ---
# GitHub Actions 上では GITHUB_REPOSITORY / GITHUB_REF_NAME から自動取得されるため未設定でよい。
GITHUB_REPO=            # 例: yourname/insta-auto
GITHUB_BRANCH=main

# --- 動作切替 ---
DRY_RUN=0               # 1 にすると実際には投稿せずログ出力のみ（疎通確認用）
